# Supabase (server-only; never expose the service role key to the client)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Admin dashboard auth
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Public site URL (used for metadata, sitemap, robots). No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Payment provider. 'simulated' uses a built-in fake gateway (no real charge).
PAYMENT_PROVIDER=simulated
