# Supabase (server-only; never expose the service role key to the client)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Admin dashboard auth. ADMIN_SESSION_SECRET signs the admin JWT session cookie
# (HS256) — use a long random string; rotating it invalidates all sessions.
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Transactional email (Resend). Required to send order confirmation receipts;
# if unset, confirmation emails are skipped (orders still confirm normally).
RESEND_API_KEY=
EMAIL_FROM=akra <orders@yourdomain.com>

# Public site URL (used for metadata, sitemap, robots). No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Payment provider. 'simulated' captures inline (no real charge); 'grow' uses
# the Grow/Meshulam hosted gateway with asynchronous webhook confirmation.
PAYMENT_PROVIDER=simulated

# Grow (Meshulam) gateway — required only when PAYMENT_PROVIDER=grow.
GROW_API_BASE=https://secure.meshulam.co.il/api/light/server/1.0
GROW_PAGE_CODE=
GROW_USER_ID=
# Shared secret used to HMAC-verify incoming payment webhooks. Keep server-only.
GROW_WEBHOOK_SECRET=
