# Supabase (server-only; never expose the service role key to the client)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Admin dashboard auth. ADMIN_SESSION_SECRET signs the admin JWT session cookie
# (HS256) — use a long random string; rotating it invalidates all sessions.
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Transactional email (Resend). Required to send order confirmation receipts;
# if unset, confirmation emails are skipped (orders still confirm normally).
RESEND_API_KEY=
EMAIL_FROM=akra <orders@yourdomain.com>

# Public site URL (used for metadata, sitemap, robots). No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Umami analytics (optional — powers /admin/statistics and visitor tracking).
# Setup: deploy/vm/umami/README.md. When unset, tracking is disabled and the
# Statistics tab shows setup instructions instead of data.
# Public (baked into the client bundle at build time):
NEXT_PUBLIC_UMAMI_SRC=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# Server-only (the admin Statistics tab queries Umami over localhost):
UMAMI_APP_URL=http://127.0.0.1:3001
UMAMI_WEBSITE_ID=
UMAMI_USERNAME=admin
UMAMI_PASSWORD=

# Payment provider:
#   'simulated' — captures inline, no real charge (local dev/testing).
#   'links'     — static Grow payment links (one per product, pasted in the admin)
#                 + our own pay page; the admin confirms each order manually in
#                 /admin/orders once payment lands in Grow. No API keys needed.
#   'grow'      — Grow/Meshulam hosted gateway (server API) with async webhook
#                 confirmation. Requires the GROW_* values below.
PAYMENT_PROVIDER=simulated

# Grow (Meshulam) server API — required only when PAYMENT_PROVIDER=grow.
# (The 'links' provider needs none of these — links are managed in the Grow dashboard.)
GROW_API_BASE=https://secure.meshulam.co.il/api/light/server/1.0
GROW_PAGE_CODE=
GROW_USER_ID=
# Shared secret used to HMAC-verify incoming payment webhooks. Keep server-only.
GROW_WEBHOOK_SECRET=
